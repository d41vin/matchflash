# Mainnet is required for Ticket 03. Do not point this worker at Devnet.
TXLINE_API_ORIGIN=https://txline.txodds.com
TXLINE_API_TOKEN=
# Optional at first launch: the worker obtains one from /auth/guest/start.
TXLINE_GUEST_JWT=

# The Convex HTTP actions site URL (https://<deployment>.convex.site, never
# .convex.cloud) and a long random ingress secret. Keep both only on this laptop.
CONVEX_SITE_URL=
MATCHFLASH_WORKER_SECRET=
