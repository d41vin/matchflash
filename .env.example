NEXT_PUBLIC_CONVEX_URL=

NEXT_PUBLIC_CONVEX_SITE_URL=

NEXT_PUBLIC_PHANTOM_APP_ID=
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3000/auth/callback

# The Next.js app signs short-lived Convex custom JWTs after it verifies a
# Phantom Solana signature. Do not expose these values to the browser.
MATCHFLASH_AUTH_ISSUER=http://localhost:3000
MATCHFLASH_AUTH_AUDIENCE=matchflash
MATCHFLASH_AUTH_JWKS_URL=http://localhost:3000/.well-known/jwks.json

PHANTOM_SOLANA_ADDRESS=

MATCHFLASH_WORKER_SECRET=

# Mainnet Bubblegum V2 Digital Trophy authority. Use a dedicated wallet only;
# it is server-only and funds every mint. Users never pay or sign a transaction.
MATCHFLASH_TROPHY_NETWORK=mainnet
MATCHFLASH_TROPHY_RPC_URL=
MATCHFLASH_TROPHY_AUTHORITY_SECRET_KEY=
# Required only for the explicit operator-only Mainnet tree-creation command.
MATCHFLASH_TROPHY_OPERATOR_SECRET=

MATCHFLASH_AUTH_PRIVATE_KEY=
MATCHFLASH_AUTH_PUBLIC_KEY=
MATCHFLASH_AUTH_CHALLENGE_SECRET=
